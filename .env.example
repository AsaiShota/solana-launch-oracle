# --- Solana RPC ---
HELIUS_API_KEY=
HELIUS_WSS_URL=wss://mainnet.helius-rpc.com/?api-key=YOUR_KEY
# Optional separate HTTPS RPC for metadata fetches; defaults to Helius mainnet HTTP
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY

# --- AI summarizer ---
ANTHROPIC_API_KEY=
# Default: claude-haiku-4-5-20251001
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# --- x402 / Base USDC ---
# IMPORTANT: replace with your actual EVM address before going live
X402_RECEIVER_ADDRESS=0x0000000000000000000000000000000000000000
X402_FACILITATOR_URL=https://api.cdp.coinbase.com/platform/v2/x402
# eip155:8453 = Base mainnet
X402_NETWORK=base

# --- Server ---
PORT=3000
DATABASE_PATH=./data/launches.db
LOG_LEVEL=info

# --- Watcher toggles (set to "false" to disable) ---
ENABLE_PUMPFUN=true
ENABLE_RAYDIUM_V4=true
ENABLE_RAYDIUM_CPMM=true
ENABLE_PUMPSWAP=true
